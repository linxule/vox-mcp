# Vox MCP Server Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# API Keys — at least one provider is required
# ===========================================
#
# Choose your approach:
# - Native APIs (Gemini/OpenAI/XAI) for direct access
# - OpenRouter for unified cloud access to many models
# - Custom endpoint for local models (Ollama, vLLM, etc.)

# Google Gemini
# Get your key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_BASE_URL=                            # Optional: Custom Gemini endpoint

# OpenAI
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Azure OpenAI — mirrors OpenAI models through Azure-hosted deployments
# Models are defined in conf/azure_models.json
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_VERSION=2024-02-15-preview
# AZURE_OPENAI_ALLOWED_MODELS=gpt-4o,gpt-4o-mini
# AZURE_MODELS_CONFIG_PATH=/absolute/path/to/custom_azure_models.json

# X.AI (Grok)
# Get your key from: https://console.x.ai/
XAI_API_KEY=your_xai_api_key_here

# Anthropic Claude — direct API access
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Moonshot AI (Kimi) — Chinese AI with extended context
# Get your key from: https://platform.moonshot.cn/
MOONSHOT_API_KEY=your_moonshot_api_key_here

# DeepSeek — cost-effective reasoning models
# Get your key from: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# OpenRouter — unified access to many models through one API
# Get your key from: https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Custom endpoint — local models (Ollama, vLLM, LM Studio, etc.)
# CUSTOM_API_URL=http://localhost:11434/v1  # Ollama example
# CUSTOM_API_KEY=                           # Empty for Ollama (no auth needed)
# CUSTOM_MODEL_NAME=llama3.2               # Default model name
# CUSTOM_MODELS_CONFIG_PATH=/path/to/your/custom_models.json

# ===========================================
# Model Selection
# ===========================================

# Default model — 'auto' lets the calling agent pick, or set a specific model name
# Examples: auto, pro, gpt-5, grok, deepseek-reasoner
# Defaults to 'auto' if not specified
DEFAULT_MODEL=auto

# Model usage restrictions — limit which models each provider exposes
# Format: Comma-separated list of allowed model names (case-insensitive)
# Empty or unset = all models allowed (default)
# To disable a provider entirely, don't set its API key
#
# Examples:
#   OPENAI_ALLOWED_MODELS=gpt-5,o4-mini     # Only these OpenAI models
#   GOOGLE_ALLOWED_MODELS=pro               # Only Gemini 2.5 Pro
#   XAI_ALLOWED_MODELS=grok-3              # Only standard Grok
#
# OPENAI_ALLOWED_MODELS=
# GOOGLE_ALLOWED_MODELS=
# XAI_ALLOWED_MODELS=

# ===========================================
# Conversation Memory
# ===========================================

# How long conversation threads persist before expiring (hours)
# Defaults to 24 if not specified
CONVERSATION_TIMEOUT_HOURS=24

# Maximum turns per conversation thread
# Each exchange (prompt + response) counts as 2 turns
# Defaults to 100 if not specified
MAX_CONVERSATION_TURNS=100

# ===========================================
# Thread Persistence
# ===========================================

# Directory for durable thread storage (append-only JSONL, one file per thread)
# Threads persist here for archival and cold-reload after memory expiry
# Defaults to ~/.vox/threads/ if not specified
# VOX_THREADS_DIR=~/.vox/threads/

# ===========================================
# Server Options
# ===========================================

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=DEBUG

# Force .env values to override system environment variables
# Useful when multiple MCP clients pass conflicting env vars
VOX_FORCE_ENV_OVERRIDE=false

# HTTP timeout tuning for OpenAI-compatible endpoints (seconds)
# Defaults: 45s connect / 900s read for remote, 60s/1800s for localhost
# CUSTOM_CONNECT_TIMEOUT=45.0
# CUSTOM_READ_TIMEOUT=900.0
# CUSTOM_WRITE_TIMEOUT=900.0
# CUSTOM_POOL_TIMEOUT=900.0

